# Copia a .env y rellena (Expo carga EXPO_PUBLIC_* automáticamente).

EXPO_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_publica

# URL base del sitio Next (web) para /api/notify-telegram y /api/notify-email al confirmar reservas.
# Opcional: si no está, la reserva se guarda en Supabase pero no se disparan esas notificaciones.
EXPO_PUBLIC_SITE_URL=https://tu-dominio.com

# Stripe: publishable en la app; la secreta (sk_) solo en Supabase Edge Function secrets, no EXPO_PUBLIC_*.
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...

# OAuth Google (opcional): fuerza el redirect_to exacto. Úsalo si Supabase sigue mandando al Site URL.
# EXPO_PUBLIC_OAUTH_REDIRECT_URI=exp://192.168.1.10:8081/--/auth/callback

# En Supabase Dashboard → Authentication → URL Configuration → Redirect URLs añade SIEMPRE:
#   exp://**
#   barberit://**
# (comodines cubren Expo Go y builds con esquema barberit; la IP del exp:// cambia en LAN).
